# Azure OpenAI credentials (required for real AI generation)
# Without these, the app falls back to a mock model that returns a static example component.
AZURE_API_KEY=your-azure-api-key
AZURE_RESOURCE_NAME=your-azure-resource-name
AZURE_DEPLOYMENT_NAME=gpt-4.1

# JWT secret for session tokens (use a long random string in production)
JWT_SECRET=your-jwt-secret-minimum-32-characters
